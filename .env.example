# AWS (legacy Nova wrappers; inactive on the OpenAI runtime path)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+3491XXXXXXX
TWILIO_API_SID=
TWILIO_API_SECRET=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_URL=https://your-server.com

# Simple request auth (iOS -> backend)
# iOS sends Authorization token: HMAC-SHA256(HABLA_SECRET, HABLA_APP_BUNDLE_ID)
# Auth is enabled when HABLA_SECRET is set.
HABLA_SECRET=
HABLA_APP_BUNDLE_ID=com.maximbilan.habla-ios

# Shared caller-id ownership service (habla-accounts)
HABLA_ACCOUNTS_BASE_URL=
HABLA_ACCOUNTS_SERVICE_TOKEN=
HABLA_ACCOUNTS_TIMEOUT_SECONDS=5

# OpenAI Realtime
OPENAI_API_KEY=
OPENAI_REALTIME_TRANSLATE_MODEL=gpt-realtime-translate
OPENAI_REALTIME_AGENT_MODEL=gpt-realtime-2
OPENAI_REALTIME_AGENT_VOICE=cedar
OPENAI_REALTIME_AGENT_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TEXT_TRANSLATION_MODEL=gpt-5.4-mini
OPENAI_AUDIO_SAMPLE_RATE=24000
