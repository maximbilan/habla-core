# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+3491XXXXXXX
TWILIO_API_SID=
TWILIO_API_SECRET=

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
PUBLIC_URL=https://your-server.com

# Simple request auth (iOS -> backend)
# iOS sends Authorization token: HMAC-SHA256(HABLA_SECRET, HABLA_APP_BUNDLE_ID)
# Auth is enabled when HABLA_SECRET is set.
HABLA_SECRET=
HABLA_APP_BUNDLE_ID=com.maximbilan.habla-ios

# Nova 2 Sonic (optional overrides)
NOVA_VOICE_ID_EN=matthew
NOVA_VOICE_ID_ES=lupe
